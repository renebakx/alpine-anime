{
  "name": "@renebakx/alpine-anime",
  "version": "1.0.0-beta-3",
  "description": "A small Alpine.js x-anime directive for viewport-driven Anime.js reveal animations.",
  "type": "module",
  "homepage": "https://renebakx.github.io/alpine-anime/",
  "module": "dist/module.js",
  "exports": {
    ".": {
      "import": "./dist/module.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renebakx/alpine-anime.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "vite build && vite build --mode cdn",
    "build:pages": "npm run build && node scripts/prepare-pages-demo.mjs",
    "release:beta": "node scripts/release-version.mjs beta",
    "release:stable": "node scripts/release-version.mjs stable",
    "test": "vitest run"
  },
  "peerDependencies": {
    "alpinejs": "^3.14.0"
  },
  "devDependencies": {
    "animejs": "^4.4.1",
    "jsdom": "^26.0.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
